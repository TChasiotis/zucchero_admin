{
  "expo": {
    "name": "Zucchero Admin",
    "slug": "zucchero-admin",
    "version": "1.2.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "zuccheroadmin",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.zuccheroadmin"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/browser_logo-removebg-preview_1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 150
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ffabdf6c-b514-415d-ac35-a0382c92af50"
      }
    }
  }
}
